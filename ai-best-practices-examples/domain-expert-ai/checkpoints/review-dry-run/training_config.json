  "grad_accum_steps": 1,
  "warmup_ratio": 0.03,
  "weight_decay": 0.0,
  "logging_steps": 10,
  "eval_strategy": "epoch",
  "save_strategy": "epoch",
  "seed": 42,
  "use_4bit": "auto",
  "target_modules": null,
  "dry_run": true,
  "template_strategy": "direct",
  "status": "dry_run"
}