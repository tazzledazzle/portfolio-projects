{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 2 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(workflow_completed_total[5m])) by (workflow_type, status)",
          "legendFormat": "{{workflow_type}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Workflow completion rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(workflow_completed_total{status=\"error\"}[5m])) / clamp_min(sum(rate(workflow_completed_total[5m])), 1e-9)",
          "legendFormat": "error ratio",
          "refId": "A"
        }
      ],
      "title": "Workflow error ratio",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "expr": "sum(increase(workflow_completed_total[1h]))",
          "legendFormat": "completions (1h)",
          "refId": "A"
        }
      ],
      "title": "Workflow completions (last 1h)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["observability", "temporal", "workflows"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Workflow Overview",
  "uid": "workflow-overview",
  "version": 1
}
